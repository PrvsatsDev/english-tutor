# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server
PORT=3000

# Paths (relative to project root)
WHISPER_BIN=./bin/whisper-cli
# Whisper model. base.en is ~3x faster than small.en on CPU with similar accuracy
# for clear English. Swap to ggml-small.en-q5_1.bin if you want better quality.
WHISPER_MODEL=./data/models/ggml-base.en-q5_1.bin
# Threads for whisper (defaults to CPU core count if unset).
# WHISPER_THREADS=6
PIPER_BIN=./bin/piper
PIPER_VOICE=./data/models/en_US-lessac-high.onnx
DB_PATH=./data/tutor.db
AUDIO_DIR=./data/audio
